# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/treeelivine?retryWrites=true&w=majority

# JWT Secret - use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# App URL (used for CORS and links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Demo mode: set to "true" to enable the Try Demo button with seeded data
DEMO_MODE=true
